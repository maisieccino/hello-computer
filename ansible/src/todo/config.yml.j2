service:
  enableregistration: false
auth:
  local:
    enabled: false
  openid:
    enabled: true
    providers:
      auth0:
        name: Auth0
        authurl: https://login.maisie.dog/
        clientid: {{ todo_auth0_client_id }}
        clientsecret: {{ todo_auth0_client_secret }}
        scope: openid profile email
